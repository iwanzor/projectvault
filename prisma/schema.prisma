  materialRequestNo String  @map("material_request_no") @db.VarChar(50)
  barcode          String   @db.VarChar(50)
  model            String   @db.VarChar(250)
  itemDescription  String   @map("item_description") @db.Text
  location         String   @db.VarChar(250)
  mainLocation     String?  @map("main_location") @db.VarChar(50)
  fobPrice         Decimal  @default(0) @map("fob_price") @db.Decimal(18, 2)
  landedCost       Decimal  @default(0) @map("landed_cost") @db.Decimal(18, 2)
  quantity         Decimal  @db.Decimal(18, 2)
  rate             Decimal  @db.Decimal(18, 2)
  amount           Decimal  @db.Decimal(18, 2)
  brandDesc        String?  @map("brand_desc") @db.VarChar(50)
  estShipPara      Decimal  @default(0) @map("est_ship_para") @db.Decimal(18, 4)
  estAmount        Decimal  @default(0) @map("est_amount") @db.Decimal(18, 2)
  estFobPrice      Decimal  @default(0) @map("est_fob_price") @db.Decimal(18, 2)
  estLandedCost    Decimal  @default(0) @map("est_landed_cost") @db.Decimal(18, 2)
  estUnitPrice     Decimal  @default(0) @map("est_unit_price") @db.Decimal(18, 2)
  estDefFob        Decimal? @map("est_def_fob") @db.Decimal(18, 2)
  estMarkup        Decimal? @map("est_markup") @db.Decimal(18, 2)
  estCustPara      Decimal? @map("est_cust_para") @db.Decimal(18, 4)
  exchangeRate     Decimal? @map("exchange_rate") @db.Decimal(18, 2)
  vatPerc          Decimal  @default(0) @map("vat_perc") @db.Decimal(18, 2)
  vatAmount        Decimal  @default(0) @map("vat_amount") @db.Decimal(18, 2)
  rowColor         Int?     @map("row_color")
  mrStatus         Int?     @map("mr_status")

  @@map("project_detail_mat_reqs")
}

// ─── FINANCE ────────────────────────────────────────

model FinancialTransaction {
  id                      Int       @id @default(autoincrement())
  transactionNo           String    @unique @map("transaction_no") @db.VarChar(50)
  category                TransactionCategory
  projectNo               String?   @map("project_no") @db.VarChar(50)
  purposeCode             String?   @map("purpose_code") @db.VarChar(50)
  description             String?   @db.VarChar(500)
  paymentChannelCode      String?   @map("payment_channel_code") @db.VarChar(50)
  internalDocNo           String?   @map("internal_doc_no") @db.VarChar(50)
  internalDocPath         String?   @map("internal_doc_path") @db.VarChar(150)
  bankCode                String?   @map("bank_code") @db.VarChar(50)
  accountNo               String?   @map("account_no") @db.VarChar(50)
  paymentTypeCode         String?   @map("payment_type_code") @db.VarChar(50)
  currency                String?   @db.VarChar(50)
  amount                  Decimal?  @db.Decimal(18, 2)
  amountPaid              Decimal?  @map("amount_paid") @db.Decimal(18, 2)
  amountLeft              Decimal?  @map("amount_left") @db.Decimal(18, 2)
  bankDocNo               String?   @map("bank_doc_no") @db.VarChar(50)
  bankDocPath             String?   @map("bank_doc_path") @db.VarChar(150)
  expectedDate            DateTime? @map("expected_date")
  actualDate              DateTime? @map("actual_date")
  statementDocPath        String?   @map("statement_doc_path") @db.VarChar(150)
  isLocked                Boolean?  @map("is_locked")
  isArchived              Boolean?  @map("is_archived")
  branchCode              String?   @map("branch_code") @db.VarChar(50)
  expectedTransactionNo   String?   @map("expected_transaction_no") @db.VarChar(50)
  descriptionLock         String?   @map("description_lock") @db.VarChar(500)
  descriptionArchive      String?   @map("description_archive") @db.VarChar(500)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("financial_transactions")
}

model InvTransactionMaster {
  id               Int      @id @default(autoincrement())
  transactionNo    String   @unique @map("transaction_no") @db.VarChar(50)
  branchCode       String   @map("branch_code") @db.VarChar(50)
  nature           Int
  transactionDate  DateTime @map("transaction_date")
  projectNo        String   @map("project_no") @db.VarChar(50)
  supplierCode     String   @map("supplier_code") @db.VarChar(50)
  description      String?  @db.VarChar(255)
  vendorInvoiceNo  String?  @map("vendor_invoice_no") @db.VarChar(50)
  requestedBy      String?  @map("requested_by") @db.VarChar(20)
  approvedBy       String?  @map("approved_by") @db.VarChar(20)
  docFilePath      String?  @map("doc_file_path") @db.VarChar(100)
  toProjectNo      String?  @map("to_project_no") @db.VarChar(10)
  createdBy        String?  @map("created_by") @db.VarChar(50)
  updatedBy        String?  @map("updated_by") @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  details InvTransactionDetail[]

  @@map("inv_transaction_masters")
}

model InvTransactionDetail {
  id                 Int     @id @default(autoincrement())
  transactionId      Int     @map("transaction_id")
  branchCode         String  @map("branch_code") @db.VarChar(50)
  nature             Int
  serialNo           Int     @map("serial_no")
  purchaseOrderNo    String  @map("purchase_order_no") @db.VarChar(50)
  barcode            String  @db.VarChar(50)
  projectNo          String  @map("project_no") @db.VarChar(50)
  itemDescription    String  @map("item_description") @db.VarChar(250)
  unitCode           String  @map("unit_code") @db.VarChar(50)
  locationCode       String  @map("location_code") @db.VarChar(50)
  quantity           Decimal @db.Decimal(18, 2)
  itemSerialNo       String  @map("item_serial_no") @db.VarChar(50)
  toProjectNo        String? @map("to_project_no") @db.VarChar(10)
  defFob             Decimal @default(0) @map("def_fob") @db.Decimal(18, 2)
  currency           String  @db.VarChar(10)
  totDefFobAmount    Decimal @default(0) @map("tot_def_fob_amount") @db.Decimal(18, 2)
  actualFob          Decimal @default(0) @map("actual_fob") @db.Decimal(18, 2)
  actualCurrency     String  @map("actual_currency") @db.VarChar(10)
  totActualFobAmount Decimal @default(0) @map("tot_actual_fob_amount") @db.Decimal(18, 2)
  convRate           Decimal @default(1) @map("conv_rate") @db.Decimal(18, 2)
  actualFobAed       Decimal @default(0) @map("actual_fob_aed") @db.Decimal(18, 2)
  totActualFobAed    Decimal @default(0) @map("tot_actual_fob_aed") @db.Decimal(18, 2)

  transaction InvTransactionMaster @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("inv_transaction_details")
}

// ─── ACCOUNTING ─────────────────────────────────────

model AccDepartment {
  id             Int      @id @default(autoincrement())
  departmentCode String   @unique @map("department_code") @db.VarChar(50)
  name           String?  @db.VarChar(50)
  description    String?  @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  timesheets AccTimesheet[]

  @@map("acc_departments")
}

model AccEmployeeStatus {
  id          Int      @id @default(autoincrement())
  statusCode  String   @unique @map("status_code") @db.VarChar(50)
  name        String?  @db.VarChar(50)
  description String?  @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  timesheets AccTimesheet[]

  @@map("acc_employee_statuses")
}

model AccEmployee {
  id             Int      @id @default(autoincrement())
  employeeCode   String   @unique @map("employee_code") @db.VarChar(50)
  firstName      String?  @map("first_name") @db.VarChar(500)
  lastName       String?  @map("last_name") @db.VarChar(500)
  nickName       String?  @map("nick_name") @db.VarChar(50)
  monthlySalary  Decimal? @map("monthly_salary") @db.Decimal(11, 2)
  isActive       Boolean? @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  timesheets AccTimesheet[]

  @@map("acc_employees")
}

model AccPosition {
  id           Int      @id @default(autoincrement())
  positionCode String   @unique @map("position_code") @db.VarChar(50)
  name         String?  @db.VarChar(50)
  description  String?  @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  timesheets AccTimesheet[]

  @@map("acc_positions")
}

model AccProject {
  id          Int      @id @default(autoincrement())
  projectCode String   @unique @map("project_code") @db.VarChar(50)
  name        String?  @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  timesheets AccTimesheet[]

  @@map("acc_projects")
}

model AccRemark {
  id         Int      @id @default(autoincrement())
  remarkCode String   @unique @map("remark_code") @db.VarChar(50)
  name       String?  @db.VarChar(50)
  description String? @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  timesheets AccTimesheet[]

  @@map("acc_remarks")
}

model AccTimesheet {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  employeeId   Int      @map("employee_id")
  projectId    Int      @map("project_id")
  positionId   Int?     @map("position_id")
  departmentId Int?     @map("department_id")
  statusId     Int?     @map("status_id")
  regularHours Decimal? @map("regular_hours") @db.Decimal(12, 0)
  extraHours   Decimal? @map("extra_hours") @db.Decimal(12, 0)
  totalHours   Decimal? @map("total_hours") @db.Decimal(12, 0)
  remarkId     Int?     @map("remark_id")

  employee   AccEmployee        @relation(fields: [employeeId], references: [id])
  project    AccProject         @relation(fields: [projectId], references: [id])
  position   AccPosition?       @relation(fields: [positionId], references: [id])
  department AccDepartment?     @relation(fields: [departmentId], references: [id])
  status     AccEmployeeStatus? @relation(fields: [statusId], references: [id])
  remark     AccRemark?         @relation(fields: [remarkId], references: [id])

  @@unique([date, employeeId, projectId])
  @@map("acc_timesheets")
}

// ─── FSF (Financial Statement Format) ──────────────

model FsfMaster {
  id          Int     @id @default(autoincrement())
  branchCode  String  @map("branch_code") @db.VarChar(50)
  note        Int
  description String  @db.VarChar(150)
  type        String  @db.VarChar(50)
  reportMode  String  @map("report_mode") @db.VarChar(50)
  nature      String  @db.VarChar(50)
  nGroup      String  @map("n_group") @db.VarChar(50)
  serial      Int
  fsfCategory String  @map("fsf_category") @db.VarChar(50)
  amount      Decimal? @db.Decimal(18, 0)

  details FsfDetail[]

  @@unique([branchCode, note])
  @@map("fsf_masters")
}

model FsfDetail {
  id          Int     @id @default(autoincrement())
  fsfMasterId Int     @map("fsf_master_id")
  branchCode  String  @map("branch_code") @db.VarChar(50)
  note        Int
  accountCode String  @map("account_code") @db.VarChar(150)
  type        String  @db.VarChar(50)
  reportMode  String  @map("report_mode") @db.VarChar(50)
  nature      String  @db.VarChar(50)
  nGroup      String  @map("n_group") @db.VarChar(50)
  serial      Int
  fsfCategory String  @map("fsf_category") @db.VarChar(50)
  amount      Decimal @db.Decimal(18, 0)

  fsfMaster FsfMaster @relation(fields: [fsfMasterId], references: [id], onDelete: Cascade)

  @@map("fsf_details")
}

