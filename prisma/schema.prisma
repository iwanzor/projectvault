// ProjectVault - Prisma Schema
// Migrated from SQL Server (BGSMART) to MySQL
// Conventions: autoincrement IDs, camelCase fields, snake_case table names via @@map

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── ENUMS ──────────────────────────────────────────

enum Module {
  SETUP
  SALES
  ACCOUNT
  PROJECT
  WAREHOUSE
  REPORTS
}

enum ItemType {
  FREE_TEXT
  ITEM
  COMBO
  OHP
  NON_SERIAL
  COST_ITEM
}

enum SQStatus {
  QUOTATION
  SUBMITTED
  PROJECT
  ARCHIVED
}

enum POStatus {
  DRAFT
  APPROVED
  RECEIVED
  CANCELLED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MRStatus {
  DRAFT
  APPROVED
  REJECTED
  COMPLETED
}

enum TransactionCategory {
  INCOME
  EXPENSE
}

// ─── AUTH & USERS ───────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  branchCode    String   @map("branch_code") @db.VarChar(50)
  userCode      String   @unique @map("user_code") @db.VarChar(50)
  username      String   @unique @db.VarChar(100)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  pcName        String?  @map("pc_name") @db.VarChar(100)
  voucherPrefix String?  @map("voucher_prefix") @db.VarChar(50)
  loginStatus    Boolean   @default(false) @map("login_status")
  isAdmin        Boolean   @default(false) @map("is_admin")
  isActive       Boolean   @default(true) @map("is_active")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  privileges    UserPrivilege[]
  sessions      UserSession[]
  projectRoles  ProjectRole[]

  @@map("users")
}

model UserPrivilege {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  module      Module
  viewAll     Boolean @default(false) @map("view_all")
  viewDetails Boolean @default(false) @map("view_details")
  canAdd      Boolean @default(false) @map("can_add")
  canEdit     Boolean @default(false) @map("can_edit")
  canDelete   Boolean @default(false) @map("can_delete")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@map("user_privileges")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

// ─── BRANCH ─────────────────────────────────────────

model Branch {
  id          Int      @id @default(autoincrement())
  branchCode  String   @unique @map("branch_code") @db.VarChar(50)
  companyCode String   @map("company_code") @db.VarChar(50)
  name        String   @db.VarChar(200)
  address1    String?  @map("address_1") @db.VarChar(300)
  address2    String?  @map("address_2") @db.VarChar(300)
  address3    String?  @map("address_3") @db.VarChar(300)
  phone       String?  @db.VarChar(50)
  fax         String?  @db.VarChar(50)
  mobile      String?  @db.VarChar(50)
  email       String?  @db.VarChar(100)
  website     String?  @db.VarChar(100)
  ntnNo       String?  @map("ntn_no") @db.VarChar(100)
  gstNo       String?  @map("gst_no") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("branches")
}

// ─── GEOGRAPHY ──────────────────────────────────────

model Country {
  id          Int      @id @default(autoincrement())
  countryCode String   @unique @map("country_code") @db.VarChar(50)
  name        String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cities City[]

  @@map("countries")
}

model City {
  id          Int      @id @default(autoincrement())
  cityCode    String   @unique @map("city_code") @db.VarChar(50)
  name        String   @db.VarChar(100)
  countryId   Int      @map("country_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  country   Country @relation(fields: [countryId], references: [id])
  areas     Area[]
  banks     Bank[]
  customers Customer[]
  suppliers Supplier[]

  @@map("cities")
}

model Area {
  id        Int      @id @default(autoincrement())
  areaCode  String   @unique @map("area_code") @db.VarChar(50)
  name      String   @db.VarChar(100)
  cityId    Int      @map("city_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city      City       @relation(fields: [cityId], references: [id])
  customers Customer[]
  suppliers Supplier[]

  @@map("areas")
}

// ─── PRODUCT MASTER DATA ────────────────────────────

model Brand {
  id        Int      @id @default(autoincrement())
  brandCode String   @unique @map("brand_code") @db.VarChar(50)
  name      String   @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items Item[]

  @@map("brands")
}

model MainCategory {
  id               Int      @id @default(autoincrement())
  mainCategoryCode String   @unique @map("main_category_code") @db.VarChar(50)
  name             String   @db.VarChar(150)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subCategories1 SubCategory1[]
  items          Item[]

  @@map("main_categories")
}

model SubCategory1 {
  id               Int      @id @default(autoincrement())
  subCategory1Code String   @unique @map("sub_category1_code") @db.VarChar(50)
  name             String   @db.VarChar(150)
  mainCategoryId   Int      @map("main_category_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  mainCategory   MainCategory   @relation(fields: [mainCategoryId], references: [id])
  subCategories2 SubCategory2[]
  items          Item[]

  @@map("sub_categories_1")
}

model SubCategory2 {
  id               Int      @id @default(autoincrement())
  subCategory2Code String   @unique @map("sub_category2_code") @db.VarChar(50)
  name             String   @db.VarChar(150)
  subCategory1Id   Int      @map("sub_category1_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subCategory1 SubCategory1 @relation(fields: [subCategory1Id], references: [id])
  items        Item[]

  @@map("sub_categories_2")
}

model Unit {
  id        Int      @id @default(autoincrement())
  unitCode  String   @unique @map("unit_code") @db.VarChar(50)
  name      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items Item[]

  @@map("units")
}

model PackingType {
  id              Int      @id @default(autoincrement())
  packingTypeCode String   @unique @map("packing_type_code") @db.VarChar(50)
  name            String   @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  items Item[]

  @@map("packing_types")
}

model Currency {
  id             Int      @id @default(autoincrement())
  currencyCode   String   @unique @map("currency_code") @db.VarChar(50)
  name           String   @db.VarChar(100)
  symbol         String?  @db.VarChar(50)
  conversionRate Decimal? @default(1.0) @map("conversion_rate") @db.Decimal(18, 4)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("currencies")
}

model VatRate {
  id        Int      @id @default(autoincrement())
  vatCode   String   @unique @map("vat_code") @db.VarChar(50)
  name      String   @db.VarChar(50)
  vatPerc   Decimal  @map("vat_perc") @db.Decimal(18, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vat_rates")
}

model QuotationTerms {
  id                 Int      @id @default(autoincrement())
  quotationTermsCode String   @unique @map("quotation_terms_code") @db.VarChar(50)
  terms              String   @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  quotations SalesQuotationMaster[]

  @@map("quotation_terms")
}

model DocumentInfo {
  id           Int      @id @default(autoincrement())
  documentCode String   @unique @map("document_code") @db.VarChar(50)
  description  String   @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projectDocuments ProjectDocumentDetail[]

  @@map("document_infos")
}

// ─── INVENTORY / ITEMS ──────────────────────────────

model Item {
  id                    Int      @id @default(autoincrement())
  barcode               String   @unique @db.VarChar(50)
  name                  String   @db.VarChar(1500)
  modelNo               String   @map("model_no") @db.VarChar(250)
  unitId                Int      @map("unit_id")
  brandId               Int      @map("brand_id")
  mainCategoryId        Int      @map("main_category_id")
  subCategory1Id        Int      @map("sub_category1_id")
  subCategory2Id        Int      @map("sub_category2_id")
  packingTypeId         Int?     @map("packing_type_id")
  supplierId            Int?     @map("supplier_id")
  currencyId            Int?     @map("currency_id")
  salesRate             Decimal  @default(0) @map("sales_rate") @db.Decimal(18, 2)
  fobPrice              Decimal  @default(0) @map("fob_price") @db.Decimal(18, 2)
  defaultPrice          Decimal  @default(0) @map("default_price") @db.Decimal(18, 2)
  estimatedArrivalPrice Decimal  @default(0) @map("estimated_arrival_price") @db.Decimal(18, 2)
  shipmentCostPara      Decimal  @default(0) @map("shipment_cost_para") @db.Decimal(18, 2)
  customsCostPara       Decimal? @default(0) @map("customs_cost_para") @db.Decimal(18, 2)
  conversionRate        Decimal? @default(1) @map("conversion_rate") @db.Decimal(18, 2)
  salesMarkup           Decimal? @default(0) @map("sales_markup") @db.Decimal(18, 2)
  vatPerc               Decimal? @default(0) @map("vat_perc") @db.Decimal(18, 2)
  maximumQuantity       Decimal  @default(0) @map("maximum_quantity") @db.Decimal(18, 2)
  minimumQuantity       Decimal  @default(0) @map("minimum_quantity") @db.Decimal(18, 2)
  reOrderQuantity       Decimal  @default(0) @map("re_order_quantity") @db.Decimal(18, 2)
  weight                Decimal  @default(0) @db.Decimal(18, 2)
  actualWeight          Decimal  @default(0) @map("actual_weight") @db.Decimal(18, 2)
  height                Decimal  @default(0) @db.Decimal(18, 2)
  depth                 Decimal  @default(0) @db.Decimal(18, 2)
  width                 Decimal? @default(0) @db.Decimal(18, 2)
  volumetricWeight      Decimal  @default(0) @map("volumetric_weight") @db.Decimal(18, 2)
  packagingDimension    Decimal  @default(0) @map("packaging_dimension") @db.Decimal(18, 2)
  itemType              ItemType @default(ITEM) @map("item_type")
  isActive              Boolean  @default(true) @map("is_active")
  isCombo               Boolean  @default(false) @map("is_combo")
  hasSerialNumber       Boolean  @default(true) @map("has_serial_number")
  isServices            Boolean  @default(false) @map("is_services")
  isAccessories         Boolean  @default(false) @map("is_accessories")
  isLabor               Boolean  @default(false) @map("is_labor")
  imagePath             String?  @map("image_path") @db.VarChar(250)
  pdfDocPath            String?  @map("pdf_doc_path") @db.VarChar(250)
  footprintPath         String?  @map("footprint_path") @db.VarChar(250)
  estimatedArrivalTime  Int?     @map("estimated_arrival_time")
  manCode1              String?  @map("man_code_1") @db.VarChar(50)
  manCode2              String?  @map("man_code_2") @db.VarChar(50)
  createdBy             String?  @map("created_by") @db.VarChar(50)
  updatedBy             String?  @map("updated_by") @db.VarChar(50)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  unit         Unit         @relation(fields: [unitId], references: [id])
  brand        Brand        @relation(fields: [brandId], references: [id])
  mainCategory MainCategory @relation(fields: [mainCategoryId], references: [id])
  subCategory1 SubCategory1 @relation(fields: [subCategory1Id], references: [id])
  subCategory2 SubCategory2 @relation(fields: [subCategory2Id], references: [id])
  packingType  PackingType? @relation(fields: [packingTypeId], references: [id])

  itemSuppliers ItemSupplier[]
  comboChildren ComboItem[]    @relation("ComboParent")
  comboParents  ComboItem[]    @relation("ComboChild")

  @@map("items")
}

model ItemSupplier {
  id         Int @id @default(autoincrement())
  itemId     Int @map("item_id")
  supplierId Int @map("supplier_id")

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([itemId, supplierId])
  @@map("item_suppliers")
}

model ComboItem {
  id                  Int      @id @default(autoincrement())
  parentItemId        Int      @map("parent_item_id")
  childItemId         Int      @map("child_item_id")
  quantity            Decimal? @db.Decimal(18, 2)
  estArrivalPrice     Decimal? @map("est_arrival_price") @db.Decimal(18, 2)
  fobPrice            Decimal? @map("fob_price") @db.Decimal(18, 2)
  defaultPrice        Decimal? @map("default_price") @db.Decimal(18, 2)
  salesPrice          Decimal? @map("sales_price") @db.Decimal(18, 2)

  parentItem Item @relation("ComboParent", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItem  Item @relation("ComboChild", fields: [childItemId], references: [id], onDelete: Cascade)

  @@unique([parentItemId, childItemId])
  @@map("combo_items")
}

// ─── PARTNERS ───────────────────────────────────────

model Customer {
  id              Int      @id @default(autoincrement())
  customerCode    String   @unique @map("customer_code") @db.VarChar(50)
  name            String   @db.VarChar(200)
  address         String?  @db.VarChar(250)
  areaId          Int?     @map("area_id")
  cityId          Int?     @map("city_id")
  phone           String?  @db.VarChar(50)
  fax             String?  @db.VarChar(50)
  mobile          String?  @db.VarChar(50)
  email           String?  @db.VarChar(100)
  other           String?  @db.VarChar(50)
  contactPerson1  String?  @map("contact_person_1") @db.VarChar(50)
  cp1Designation  String?  @map("cp1_designation") @db.VarChar(50)
  cp1Email        String?  @map("cp1_email") @db.VarChar(50)
  cp1Mobile       String?  @map("cp1_mobile") @db.VarChar(50)
  contactPerson2  String?  @map("contact_person_2") @db.VarChar(50)
  cp2Designation  String?  @map("cp2_designation") @db.VarChar(50)
  cp2Email        String?  @map("cp2_email") @db.VarChar(50)
  cp2Mobile       String?  @map("cp2_mobile") @db.VarChar(50)
  contactPerson3  String?  @map("contact_person_3") @db.VarChar(50)
  cp3Designation  String?  @map("cp3_designation") @db.VarChar(50)
  cp3Email        String?  @map("cp3_email") @db.VarChar(50)
  cp3Mobile       String?  @map("cp3_mobile") @db.VarChar(50)
  gpCustomerId    String?  @map("gp_customer_id") @db.VarChar(10)
  isExport        Boolean  @default(false) @map("is_export")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  area       Area?                  @relation(fields: [areaId], references: [id])
  city       City?                  @relation(fields: [cityId], references: [id])
  quotations SalesQuotationMaster[]
  projects   ProjectMaster[]

  @@map("customers")
}

model Supplier {
  id             Int      @id @default(autoincrement())
  supplierCode   String   @unique @map("supplier_code") @db.VarChar(50)
  name           String   @db.VarChar(200)
  address        String?  @db.VarChar(250)
  areaId         Int?     @map("area_id")
  cityId         Int?     @map("city_id")
  phone          String?  @db.VarChar(250)
  fax            String?  @db.VarChar(50)
  mobile         String?  @db.VarChar(50)
  email          String?  @db.VarChar(100)
  other          String?  @db.VarChar(50)
  contactPerson1 String?  @map("contact_person_1") @db.VarChar(50)
  cp1Designation String?  @map("cp1_designation") @db.VarChar(50)
  cp1Email       String?  @map("cp1_email") @db.VarChar(50)
  cp1Mobile      String?  @map("cp1_mobile") @db.VarChar(50)
  contactPerson2 String?  @map("contact_person_2") @db.VarChar(50)
  cp2Designation String?  @map("cp2_designation") @db.VarChar(50)
  cp2Email       String?  @map("cp2_email") @db.VarChar(50)
  cp2Mobile      String?  @map("cp2_mobile") @db.VarChar(50)
  contactPerson3 String?  @map("contact_person_3") @db.VarChar(50)
  cp3Designation String?  @map("cp3_designation") @db.VarChar(50)
  cp3Email       String?  @map("cp3_email") @db.VarChar(50)
  cp3Mobile      String?  @map("cp3_mobile") @db.VarChar(50)
  currencyCode   String?  @map("currency_code") @db.VarChar(50)
  vendorCode     String?  @map("vendor_code") @db.VarChar(50)
  isImport       Boolean  @default(false) @map("is_import")
  terms          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  area           Area?                  @relation(fields: [areaId], references: [id])
  city           City?                  @relation(fields: [cityId], references: [id])
  itemSuppliers  ItemSupplier[]
  purchaseOrders PurchaseOrderMaster[]
  grnMasters     GrnMaster[]

  @@map("suppliers")
}

model Bank {
  id             Int      @id @default(autoincrement())
  bankCode       String   @unique @map("bank_code") @db.VarChar(50)
  branchCode     String   @map("branch_code") @db.VarChar(50)
  name           String   @db.VarChar(100)
  address        String?  @db.VarChar(250)
  cityId         Int?     @map("city_id")
  phone          String?  @db.VarChar(50)
  fax            String?  @db.VarChar(50)
  mobile         String?  @db.VarChar(50)
  contactPerson1 String?  @map("contact_person_1") @db.VarChar(50)
  contactPerson2 String?  @map("contact_person_2") @db.VarChar(50)
  contactPerson3 String?  @map("contact_person_3") @db.VarChar(50)
  isGst          Boolean  @default(false) @map("is_gst")
  isCreditCard   Boolean  @default(false) @map("is_credit_card")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  city     City?         @relation(fields: [cityId], references: [id])
  accounts BankAccount[]

  @@map("banks")
}

model BankAccount {
  id           Int      @id @default(autoincrement())
  bankId       Int      @map("bank_id")
  accountNo    String   @map("account_no") @db.VarChar(50)
  accountType  String?  @map("account_type") @db.VarChar(50)
  currencyCode String?  @map("currency_code") @db.VarChar(50)
  amount       Decimal? @db.Decimal(18, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@unique([bankId, accountNo])
  @@map("bank_accounts")
}

// ─── SALES QUOTATIONS ──────────────────────────────

model SalesQuotationMaster {
  id                 Int        @id @default(autoincrement())
  quotationNo        String     @unique @map("quotation_no") @db.VarChar(50)
  branchCode         String     @map("branch_code") @db.VarChar(50)
  quotationDate      DateTime   @map("quotation_date")
  customerId         Int        @map("customer_id")
  quotationTermsId   Int?       @map("quotation_terms_id")
  description        String?    @db.Text
  status             SQStatus   @default(QUOTATION)
  revisionNo         Int        @default(0) @map("revision_no")
  totalAmount        Decimal    @default(0) @map("total_amount") @db.Decimal(18, 2)
  discountPercentage Decimal    @default(0) @map("discount_percentage") @db.Decimal(18, 2)
  discountAmount     Decimal    @default(0) @map("discount_amount") @db.Decimal(18, 2)
  netAmount          Decimal    @default(0) @map("net_amount") @db.Decimal(18, 2)
  vatPerc            Decimal    @default(0) @map("vat_perc") @db.Decimal(18, 2)
  vatAmount          Decimal    @default(0) @map("vat_amount") @db.Decimal(18, 2)
  grossTotal         Decimal    @default(0) @map("gross_total") @db.Decimal(18, 2)
  commPerc           Decimal?   @map("comm_perc") @db.Decimal(18, 2)
  commAmount         Decimal?   @map("comm_amount") @db.Decimal(18, 2)
  committedBy        String?    @map("committed_by") @db.VarChar(50)
  committedDate      DateTime?  @map("committed_date")
  hasRevision        Boolean    @default(false) @map("has_revision")
  usedInProject      Boolean    @default(false) @map("used_in_project")
  isArchived         Boolean    @default(false) @map("is_archived")
  createdBy          String?    @map("created_by") @db.VarChar(50)
  updatedBy          String?    @map("updated_by") @db.VarChar(50)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  customer       Customer               @relation(fields: [customerId], references: [id])
  quotationTerms QuotationTerms?        @relation(fields: [quotationTermsId], references: [id])
  details        SalesQuotationDetail[]
  remarks        QuotationRemark[]
  projects       ProjectMaster[]

  @@map("sales_quotation_masters")
}

model SalesQuotationDetail {
  id               Int      @id @default(autoincrement())
  quotationId      Int      @map("quotation_id")
  branchCode       String   @map("branch_code") @db.VarChar(50)
  barcode          String   @db.VarChar(50)
  serialNo         Int      @map("serial_no")
  itemDescription  String   @map("item_description") @db.Text
  model            String   @db.VarChar(250)
  location         String?  @db.VarChar(500)
  mainLocation     String?  @map("main_location") @db.VarChar(500)
  quantity         Decimal  @db.Decimal(18, 2)
  rate             Decimal  @db.Decimal(18, 2)
  amount           Decimal  @db.Decimal(18, 2)
  fobPrice         Decimal  @default(0) @map("fob_price") @db.Decimal(18, 2)
  landedCost       Decimal  @default(0) @map("landed_cost") @db.Decimal(18, 2)
  brandDesc        String?  @map("brand_desc") @db.VarChar(50)
  itemPicPath      String?  @map("item_pic_path") @db.VarChar(250)
  estShipPara      Decimal  @default(0) @map("est_ship_para") @db.Decimal(18, 4)
  estAmount        Decimal  @default(0) @map("est_amount") @db.Decimal(18, 2)
  estFobPrice      Decimal  @default(0) @map("est_fob_price") @db.Decimal(18, 2)
